# Neon Postgres connection string (Project → Connection Details → "pooled")
DATABASE_URL="postgresql://user:password@ep-xxxxx.aws.neon.tech/neondb?sslmode=require"

# Auth.js — generate with: openssl rand -base64 32  (or use https://generate-secret.vercel.app/32)
AUTH_SECRET=""

# Google OAuth (Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID, "Web application")
# Authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://<your-vercel-domain>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Allowed login domains (comma-separated)
ALLOWED_EMAIL_DOMAINS="openhouse.in,openhouse.com"
